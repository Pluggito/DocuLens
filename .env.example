# ─── Database ───
DATABASE_URL="postgresql://user:pass@host/dbname"      # Neon Postgres connection string

# ─── Auth ───
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"  # JWT signing secret
NEXTAUTH_URL="http://localhost:3000"                     # App URL (dev)
# GOOGLE_CLIENT_ID="your-google-client-id"               # Optional: Google OAuth
# GOOGLE_CLIENT_SECRET="your-google-client-secret"       # Optional: Google OAuth

# ─── Storage ───
BLOB_READ_WRITE_TOKEN="vercel-blob-token"                # Vercel Blob file storage

# ─── AI ───
GOOGLE_GENERATIVE_AI_API_KEY="gemini-api-key"            # Google Gemini Flash

# ─── Cache (Optional) ───
# UPSTASH_REDIS_REST_URL="https://your-instance.upstash.io"
# UPSTASH_REDIS_REST_TOKEN="your-upstash-token"
